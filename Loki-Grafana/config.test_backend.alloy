// peer_backend flat + nested logs  (use ** to recurse if needed)
local.file_match "backend_logs" {
  path_targets = [
    { __path__ = "/var/www/peer_beta/peer_backend/runtime-data/logs/**/*", job = "backend_logs", host = "test-backend-server" },
  ]
}
loki.source.file "backend_logs" {
  targets     = local.file_match.backend_logs.targets
  forward_to  = [loki.write.default.receiver]
}


