// webhook single file (no discovery needed because it's a single exact file)
loki.source.file "webhook_log" {
  targets     = [
    { __path__ = "/var/log/webhook.log", job = "peer_backend_webhook", host = "test-backend-server" },
  ]
  forward_to  = [loki.write.default.receiver]
}